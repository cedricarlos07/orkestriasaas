# Local dev — http://localhost:8080

DATABASE_URL=postgresql://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require
BETTER_AUTH_SECRET=generate-with-openssl-rand-base64-32
BETTER_AUTH_URL=http://localhost:8080
TOKEN_ENCRYPTION_KEY=generate-with-openssl-rand-base64-32

# User login OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Ad platform OAuth (REQUIRED — no demo mode)
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

GOOGLE_ANALYTICS_CLIENT_ID=
GOOGLE_ANALYTICS_CLIENT_SECRET=

META_APP_ID=
META_APP_SECRET=

TIKTOK_APP_ID=
TIKTOK_APP_SECRET=

LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

SNAPCHAT_CLIENT_ID=
SNAPCHAT_CLIENT_SECRET=

REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

MICROSOFT_ADS_CLIENT_ID=
MICROSOFT_ADS_CLIENT_SECRET=
MICROSOFT_ADS_DEVELOPER_TOKEN=

X_ADS_CLIENT_ID=
X_ADS_CLIENT_SECRET=

AMAZON_ADS_CLIENT_ID=
AMAZON_ADS_CLIENT_SECRET=

PINTEREST_CLIENT_ID=
PINTEREST_CLIENT_SECRET=

# AdKit (unified Meta/Google/TikTok/Reddit MCP — draft-first)
# Create key: https://app.adkit.so → Devices & Keys
# Docs: https://adkit.so/docs/getting-started
ADKIT_API_KEY=
ADKIT_MCP_URL=https://mcp.adkit.so
# Optional: default AdKit project for multi-brand workspaces
# ADKIT_PROJECT_ID=
# FCFA → USD when AdKit Meta account is USD (default 600)
# ADKIT_XOF_PER_USD=600

# MCP sidecar URLs (optional — if unset, Orkestria uses AdKit when ADKIT_API_KEY is set, else direct APIs)
MCP_GOOGLE_ADS_READ_URL=http://localhost:3101/mcp
MCP_GOOGLE_ADS_WRITE_URL=http://localhost:3102/mcp
MCP_META_ADS_URL=
MCP_TIKTOK_ADS_URL=http://localhost:3103/mcp
MCP_GA4_URL=http://localhost:3104/mcp

# Write actions (Meta pause, Google budget) — set true only after sandbox validation
MCP_WRITE_ENABLED=false

# LLM orchestrator (REQUIRED for chat beyond audit)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
