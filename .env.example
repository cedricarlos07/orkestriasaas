# Local dev — http://localhost:8080

DATABASE_URL=postgresql://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require
BETTER_AUTH_SECRET=generate-with-openssl-rand-base64-32
BETTER_AUTH_URL=http://localhost:8080
TOKEN_ENCRYPTION_KEY=generate-with-openssl-rand-base64-32

# User login OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Ad platform OAuth (REQUIRED — no demo mode)
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

GOOGLE_ANALYTICS_CLIENT_ID=
GOOGLE_ANALYTICS_CLIENT_SECRET=

META_APP_ID=
META_APP_SECRET=

TIKTOK_APP_ID=
TIKTOK_APP_SECRET=

LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

SNAPCHAT_CLIENT_ID=
SNAPCHAT_CLIENT_SECRET=

REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

MICROSOFT_ADS_CLIENT_ID=
MICROSOFT_ADS_CLIENT_SECRET=
MICROSOFT_ADS_DEVELOPER_TOKEN=

X_ADS_CLIENT_ID=
X_ADS_CLIENT_SECRET=

AMAZON_ADS_CLIENT_ID=
AMAZON_ADS_CLIENT_SECRET=

PINTEREST_CLIENT_ID=
PINTEREST_CLIENT_SECRET=

# Research — Meta Ad Library (useproxy / Proxy)
USEPROXY_MCP_URL=https://mcp.useproxy.dev/mcp
USEPROXY_API_KEY=

# Meta via adkit (https://github.com/jatinjain25/adkit) — subprocess adkit-mcp
# pipx install "meta-adkit[mcp]"
ADKIT_MCP_COMMAND=adkit-mcp
# ADKIT_MCP_ARGS=
# ADKIT_PROBE_TOKEN=   # optional health check
# ADKIT_PROBE_ACCOUNT=act_...
# META_PAGE_ID=        # default page if tool omits pageId
# META_INSTAGRAM_ACTOR_ID=
# GEMINI_API_KEY=      # optional — adkit generate_image/video
# ADVERTISER_URL=https://your-site.com

# Google via AdLoop Cloud (fallback dev ; prod = clé alc_ par org)
ADLOOP_MCP_URL=https://mcp.getadloop.com/mcp
ADLOOP_API_KEY=

# Write actions — set true only after sandbox validation
MCP_WRITE_ENABLED=false

# LLM orchestrator (REQUIRED for chat beyond audit)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
