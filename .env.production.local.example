# Production secrets for orkestria.top — copy to .env.production.local (gitignored via *.local)
#
# Meta Developer Console (developers.facebook.com):
#   1. App → Settings → Valid OAuth Redirect URIs:
#      https://orkestria.top/api/oauth/meta_ads/callback
#   2. App Review: ads_read + ads_management (Live mode or test users)
#   3. Paste App ID + App Secret below
#
# Apply to Openship: node scripts/sync-prod-env-to-openship.mjs
# (or patch Openship project proj_B9pE6w3WyxEphAYA env production)

META_APP_ID=
META_APP_SECRET=
META_PAGE_ID=
META_API_VERSION=v21.0
ADVERTISER_URL=https://your-site.com

DEEPSEEK_API_KEY=
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-flash
LLM_MODEL_THINKING=deepseek-v4-flash

STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Research — useproxy OAuth bearer (after connecting useproxy MCP once)
USEPROXY_MCP_URL=https://mcp.useproxy.dev/mcp
USEPROXY_BEARER_TOKEN=

# Meta automation — adkit subprocess (pip install "meta-adkit[mcp]" in Docker)
ADKIT_MCP_COMMAND=adkit-mcp
# GEMINI_API_KEY=

# Google via AdLoop self-hosted (adloop init once on VPS)
ADLOOP_MCP_COMMAND=python3
ADLOOP_MCP_ARGS=-m adloop
# ADLOOP_CONFIG=/root/.adloop/config.yaml

MCP_WRITE_ENABLED=true
