# Secrets à ajouter quand tu les as (Openship → proj_B9pE6w3WyxEphAYA → env production)
#
# META_APP_ID=
# META_APP_SECRET=
# DEEPSEEK_API_KEY=
# USEPROXY_BEARER_TOKEN=   # Bearer OAuth après connexion useproxy (pas de clé API séparée)
# USEPROXY_API_KEY=        # alias legacy, même valeur
# STRIPE_SECRET_KEY=       # rk_live_... or sk_live_...
# STRIPE_PUBLISHABLE_KEY=  # pk_live_...
# STRIPE_WEBHOOK_SECRET=   # whsec_... from Stripe webhook endpoint
# GOOGLE_ADS_CLIENT_ID=          (optional)
# GOOGLE_ADS_CLIENT_SECRET=      (optional)
# SMTP_HOST=mail.orkestria.top   # Openship Mail
# SMTP_PORT=587
# SMTP_USER=hello@orkestria.top
# SMTP_PASSWORD=
# SMTP_FROM=Orkestria <hello@orkestria.top>
# SMTP_NOTIFY_TO=hello@orkestria.top
#
# Déjà configuré côté Openship (non-secret) :
# USEPROXY_MCP_URL=https://mcp.useproxy.dev/mcp
# ADLOOP_MCP_COMMAND=python3
# ADLOOP_CONFIG=/root/.adloop/config.yaml
# ADKIT_MCP_COMMAND=adkit-mcp
# META_API_VERSION=v21.0
# MCP_WRITE_ENABLED=true
#
# Sync : remplir ce fichier → copier en .env.production.local → node scripts/sync-prod-env-to-openship.mjs
